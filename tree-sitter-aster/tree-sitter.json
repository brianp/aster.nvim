{
  "grammars": [
    {
      "name": "aster",
      "camelcase": "Aster",
      "scope": "source.aster",
      "path": ".",
      "file-types": [
        "aster",
        "astr"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^aster$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Aster programming language",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-aster"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
